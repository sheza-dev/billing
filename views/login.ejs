<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t('customer.login_title', 'Login Pelanggan') %> | <%= settings.company_header || 'Portal ISP' %></title>
  <!-- Preconnect to CDN for faster loading -->
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="theme-color" content="#0f172a">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <link rel="apple-touch-icon" href="/img/logo.png">
  <link rel="icon" href="/img/logo.png">
  <style>
    .login-container {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .login-card {
      max-width: 420px;
      width: 100%;
      overflow: hidden;
      border-radius: 24px !important;
    }

    .login-header {
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.08) 0%, rgba(59, 130, 246, 0.04) 100%);
      color: #f8fafc;
      padding: 35px 25px 25px;
      text-align: center;
      border-bottom: 1px solid var(--border-glass);
    }

    .logo-container {
      width: 80px;
      height: 80px;
      background: rgba(15, 23, 42, 0.55);
      border: 2px solid rgba(99, 102, 241, 0.35);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 18px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3), 
                  0 0 15px rgba(99, 102, 241, 0.15);
      transition: var(--transition-smooth);
    }

    .logo-container:hover {
      transform: scale(1.05) rotate(4deg);
      border-color: rgba(99, 102, 241, 0.6);
      box-shadow: 0 12px 32px rgba(99, 102, 241, 0.4), 
                  0 0 20px rgba(99, 102, 241, 0.3);
    }

    .logo-img {
      width: 50px;
      height: 50px;
      object-fit: contain;
      border-radius: 50%;
      background: transparent !important;
      box-shadow: none !important;
      padding: 0 !important;
    }

    .logo-img:hover {
      transform: none !important;
      box-shadow: none !important;
    }

    .form-container {
      padding: 30px 28px;
    }

    .form-floating {
      margin-bottom: 22px;
    }

    .form-control {
      background: rgba(15, 23, 42, 0.55) !important;
      border: 1px solid var(--border-glass) !important;
      color: #e2e8f0 !important;
      border-radius: 12px !important;
      padding: 15px 20px !important;
      font-size: 16px !important;
      transition: var(--transition-smooth) !important;
    }

    .form-control:focus {
      background: rgba(15, 23, 42, 0.75) !important;
      border-color: rgba(99, 102, 241, 0.8) !important;
      box-shadow: 0 0 0 0.25rem rgba(99, 102, 241, 0.2) !important;
      color: #f1f5f9 !important;
    }

    /* Autofill overrides for premium look */
    .form-control:-webkit-autofill,
    .form-control:-webkit-autofill:hover,
    .form-control:-webkit-autofill:focus {
      -webkit-text-fill-color: #f1f5f9 !important;
      -webkit-box-shadow: 0 0 0px 1000px rgba(15, 23, 42, 0.75) inset !important;
      transition: background-color 5000s ease-in-out 0s;
    }

    .form-floating>label {
      color: var(--text-mute) !important;
      padding-left: 20px !important;
    }

    .form-floating>.form-control:focus~label {
      color: #a5b4fc !important;
      opacity: 1 !important;
    }

    .form-floating>.form-control:not(:placeholder-shown)~label {
      color: var(--text-mute) !important;
      opacity: 0.8 !important;
    }

    /* Prevent white background flash behind floating label */
    .form-floating>.form-control:focus~label::after,
    .form-floating>.form-control:not(:placeholder-shown)~label::after {
      background-color: transparent !important;
    }

    .alert {
      border: 1px solid rgba(239, 68, 68, 0.25) !important;
      background: rgba(239, 68, 68, 0.08) !important;
      color: #fee2e2 !important;
      border-radius: 12px;
      backdrop-filter: blur(4px);
    }

    .quick-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: 15px;
    }

    .info-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
      margin-top: 20px;
    }

    .info-box {
      border: 1px solid var(--border-glass);
      background: rgba(15, 23, 42, 0.25);
      border-radius: 14px;
      padding: 14px 16px;
      transition: var(--transition-smooth);
    }

    .info-box:hover {
      border-color: var(--border-glass-hover);
      background: rgba(15, 23, 42, 0.4);
      transform: translateY(-1px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    }

    .info-title {
      font-weight: 700;
      font-size: 13px;
      color: #cbd5e1;
      margin-bottom: 5px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .info-text {
      color: var(--text-mute);
      font-size: 12px;
      line-height: 1.4;
      margin: 0;
    }

    /* Premium custom scrollbar for package list */
    .info-box div::-webkit-scrollbar {
      width: 4px;
    }
    .info-box div::-webkit-scrollbar-track {
      background: transparent;
    }
    .info-box div::-webkit-scrollbar-thumb {
      background: rgba(99, 102, 241, 0.2);
      border-radius: 2px;
    }
    .info-box div::-webkit-scrollbar-thumb:hover {
      background: rgba(99, 102, 241, 0.5);
    }

    .footer-link {
      color: var(--text-mute) !important;
      transition: var(--transition-smooth);
      font-size: 13px;
      text-decoration: none;
    }

    .footer-link:hover {
      color: #a5b4fc !important;
      text-shadow: 0 0 8px rgba(165, 180, 252, 0.4);
    }

    body {
      background-attachment: fixed !important;
    }

    @media (max-width: 576px) {
      .login-container {
        padding: 10px;
      }

      .login-card {
        border-radius: 20px !important;
      }

      .form-container {
        padding: 25px 20px;
      }

      .quick-actions {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>
  <div class="login-container">
    <div class="login-card card-glass glow-border">
      <div class="login-header">
        <div class="logo-container">
          <img src="/img/logo.png" class="logo-img" alt="Logo">
        </div>
        <h4 class="mb-1 fw-bold"><%= t('customer.portal_title', 'Portal Pelanggan') %></h4>
        <p class="mb-0 opacity-75">
          <%= settings.company_header %>
        </p>
      </div>
      <div class="form-container">
        <form method="POST" action="/customer/login">
          <div class="form-floating">
            <input type="text" class="form-control" id="phone" name="phone" placeholder="<%= t('customer.id_tag_placeholder', 'Masukkan ID/Tag Pelanggan') %>"
              required autofocus>
            <label for="phone">
              <i class="bi bi-person-badge me-2"></i><%= t('customer.id_tag', 'ID/Tag Pelanggan') %>
            </label>
          </div>
          <div class="text-center mb-3 small" style="color: var(--text-mute);">
            <i class="bi bi-info-circle me-1"></i>
            Masukkan ID pelanggan / Nomor HP yang terdaftar
          </div>
          <% if (settings.login_otp_enabled) { %>
            <div class="text-center mb-3 small" style="color: var(--text-mute);">
              <i class="bi bi-whatsapp text-success me-1"></i> <%= t('customer.otp_sent_via_wa', 'Kode OTP akan dikirim via WhatsApp') %>
            </div>
          <% } %>
          <button type="submit" class="btn btn-primary-glow w-100 py-3 mb-2">
            <i class="bi bi-box-arrow-in-right me-2"></i><%= t('customer.sign_in', 'Masuk') %>
          </button>
          <div class="quick-actions">
            <a href="/customer/check-billing" class="btn btn-ghost-glass py-3">
              <i class="bi bi-receipt me-1"></i>Cek Tagihan
            </a>
            <a href="/customer/voucher" class="btn btn-ghost-glass py-3">
              <i class="bi bi-ticket-perforated me-1"></i>Voucher
            </a>
          </div>
        </form>
        <% if (error) { %>
          <div class="alert alert-danger mt-3 text-center">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <%= error==='Nomor HP tidak valid atau belum terdaftar.' ? 'ID/Tag tidak valid atau belum terdaftar.' : error %>
          </div>
        <% } %>

        <div class="info-grid">
          <div class="info-box">
            <div class="info-title"><i class="bi bi-lightning-charge text-warning"></i> Akses Cepat</div>
            <p class="info-text">Cek tagihan dan beli voucher bisa dilakukan tanpa login.</p>
          </div>
          <div class="info-box">
            <div class="info-title"><i class="bi bi-clock text-info"></i> Jam Operasional</div>
            <p class="info-text"><%= settings.operational_hours || 'Setiap Hari' %></p>
          </div>
          <% if (settings.company_phone) { %>
            <div class="info-box">
              <div class="info-title"><i class="bi bi-headset text-success"></i> Bantuan</div>
              <p class="info-text">
                WhatsApp: <a href="https://wa.me/<%= String(settings.company_phone).replace(/\D/g,'') %>" target="_blank" rel="noopener" style="color:#a5b4fc;text-decoration:none;font-weight:700"><%= settings.company_phone %></a>
                <% if (settings.company_email) { %>
                  <br>Email: <a href="mailto:<%= settings.company_email %>" style="color:#a5b4fc;text-decoration:none;font-weight:700"><%= settings.company_email %></a>
                <% } %>
              </p>
            </div>
          <% } %>
          <div class="info-box">
            <div class="info-title"><i class="bi bi-wifi text-primary"></i> Paket & Harga</div>
            <% const pkgs = (typeof packages !== 'undefined' && Array.isArray(packages)) ? packages : []; %>
            <% if (pkgs.length === 0) { %>
              <p class="info-text">Belum ada paket yang aktif.</p>
            <% } else { %>
              <% const list = pkgs.slice().sort((a,b) => Number(a.price||0) - Number(b.price||0)); %>
              <div style="max-height:160px;overflow:auto;padding-right:4px">
                <% list.forEach(p => { %>
                  <div style="padding:8px 0;border-top:1px solid rgba(148,163,184,.12)">
                    <div style="font-weight:700;font-size:12px;color:#f1f5f9">
                      <%= p.name %> — Rp <%= Number(p.price||0).toLocaleString('id-ID') %>/bulan
                    </div>
                    <div class="info-text" style="margin-top:2px">
                      <% if (Number(p.speed_down||0) > 0 || Number(p.speed_up||0) > 0) { %>
                        <span><%= Number(p.speed_down||0) > 0 ? (Math.round(Number(p.speed_down||0)/1000) + ' Mbps') : '-' %> / <%= Number(p.speed_up||0) > 0 ? (Math.round(Number(p.speed_up||0)/1000) + ' Mbps') : '-' %></span>
                        <span> • </span>
                      <% } %>
                      <span><%= p.description ? String(p.description) : '-' %></span>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>

        <div class="text-center footer-text mt-4">
          <p class="mb-3"><%= t('customer.not_subscribed', 'Belum berlangganan?') %> <a href="/customer/register"
              style="color: #6366f1; text-decoration: none; font-weight: 700;"><%= t('customer.register_new', 'Daftar Pemasangan Baru') %></a></p>
          
          <div class="d-flex flex-wrap justify-content-center gap-3 mb-3">
            <a href="/customer/about" class="footer-link"><%= t('customer.footer.about', 'Tentang Kami') %></a>
            <a href="/customer/contact" class="footer-link"><%= t('customer.footer.contact', 'Kontak') %></a>
            <a href="/customer/tos" class="footer-link"><%= t('customer.footer.tos', 'Syarat & Ketentuan') %></a>
            <a href="/customer/privacy" class="footer-link"><%= t('customer.footer.privacy', 'Kebijakan Privasi') %></a>
            <a href="/customer/tos#refund" class="footer-link"><%= t('customer.footer.refund', 'Kebijakan Refund') %></a>
          </div>

          &copy; <%= new Date().getFullYear() %> <%= settings.company_header %>
        </div>
      </div>
    </div>
  </div>
  <script>
    if ('serviceWorker' in navigator) {
      setTimeout(() => {
        navigator.serviceWorker.register('/sw.js', { scope: '/customer/' }).catch(() => {});
      }, 2000);
    }
    
    window.addEventListener('load', () => {
      document.getElementById('phone')?.focus();
    });
  </script>
</body>

</html>
