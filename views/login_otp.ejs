<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t('customer.otp_title', 'Verifikasi OTP') %> | <%= settings.company_header || 'Portal ISP' %></title>
  <!-- Preconnect to CDN for faster loading -->
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="theme-color" content="#0f172a">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <link rel="apple-touch-icon" href="/img/logo.png">
  <link rel="icon" href="/img/logo.png">
  <style>
    .login-container {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .login-card {
      max-width: 420px;
      width: 100%;
      overflow: hidden;
      border-radius: 24px !important;
    }

    .login-header {
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.08) 0%, rgba(59, 130, 246, 0.04) 100%);
      color: #f8fafc;
      padding: 35px 25px 25px;
      text-align: center;
      border-bottom: 1px solid var(--border-glass);
    }

    .logo-container {
      width: 80px;
      height: 80px;
      background: rgba(15, 23, 42, 0.55);
      border: 2px solid rgba(99, 102, 241, 0.35);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 18px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3), 
                  0 0 15px rgba(99, 102, 241, 0.15);
      transition: var(--transition-smooth);
    }

    .logo-container:hover {
      transform: scale(1.05) rotate(4deg);
      border-color: rgba(99, 102, 241, 0.6);
      box-shadow: 0 12px 32px rgba(99, 102, 241, 0.4), 
                  0 0 20px rgba(99, 102, 241, 0.3);
    }

    .logo-img {
      width: 50px;
      height: 50px;
      object-fit: contain;
      border-radius: 50%;
      background: transparent !important;
      box-shadow: none !important;
      padding: 0 !important;
    }

    .logo-img:hover {
      transform: none !important;
      box-shadow: none !important;
    }

    .form-container {
      padding: 30px 28px;
    }

    .form-floating {
      margin-bottom: 22px;
    }

    .form-control {
      background: rgba(15, 23, 42, 0.55) !important;
      border: 1px solid var(--border-glass) !important;
      color: #e2e8f0 !important;
      border-radius: 12px !important;
      padding: 15px 20px !important;
      font-size: 16px !important;
      transition: var(--transition-smooth) !important;
    }

    .form-control:focus {
      background: rgba(15, 23, 42, 0.75) !important;
      border-color: rgba(99, 102, 241, 0.8) !important;
      box-shadow: 0 0 0 0.25rem rgba(99, 102, 241, 0.2) !important;
      color: #f1f5f9 !important;
    }

    .otp-input {
      letter-spacing: 12px;
      font-size: 24px;
      font-weight: 700;
      text-align: center;
    }

    /* Autofill overrides for premium look */
    .form-control:-webkit-autofill,
    .form-control:-webkit-autofill:hover,
    .form-control:-webkit-autofill:focus {
      -webkit-text-fill-color: #f1f5f9 !important;
      -webkit-box-shadow: 0 0 0px 1000px rgba(15, 23, 42, 0.75) inset !important;
      transition: background-color 5000s ease-in-out 0s;
    }

    .form-floating>label {
      color: var(--text-mute) !important;
      padding-left: 20px !important;
    }

    .form-floating>.form-control:focus~label {
      color: #a5b4fc !important;
      opacity: 1 !important;
    }

    .form-floating>.form-control:not(:placeholder-shown)~label {
      color: var(--text-mute) !important;
      opacity: 0.8 !important;
    }

    /* Prevent white background flash behind floating label */
    .form-floating>.form-control:focus~label::after,
    .form-floating>.form-control:not(:placeholder-shown)~label::after {
      background-color: transparent !important;
    }

    .alert {
      border: 1px solid rgba(239, 68, 68, 0.25) !important;
      background: rgba(239, 68, 68, 0.08) !important;
      color: #fee2e2 !important;
      border-radius: 12px;
      backdrop-filter: blur(4px);
    }

    .footer-link {
      color: var(--text-mute) !important;
      transition: var(--transition-smooth);
      font-size: 13px;
      text-decoration: none;
    }

    .footer-link:hover {
      color: #a5b4fc !important;
      text-shadow: 0 0 8px rgba(165, 180, 252, 0.4);
    }

    body {
      background-attachment: fixed !important;
    }

    @media (max-width: 576px) {
      .login-container {
        padding: 10px;
      }

      .login-card {
        border-radius: 20px !important;
      }

      .form-container {
        padding: 25px 20px;
      }
    }
  </style>
</head>

<body>
  <div class="login-container">
    <div class="login-card card-glass glow-border">
      <div class="login-header">
        <div class="logo-container">
          <img src="/img/logo.png" class="logo-img" alt="Logo">
        </div>
        <h4 class="mb-1 fw-bold"><%= t('customer.otp_title', 'Verifikasi OTP') %></h4>
        <p class="mb-0 opacity-75">
          <%= settings.company_header %>
        </p>
      </div>
      <div class="form-container">
        <div class="text-center mb-4 small" style="color: var(--text-mute);">
          <i class="bi bi-whatsapp text-success me-1"></i>
          <%= t('customer.otp_sent_info', 'Kode verifikasi telah dikirim ke nomor WhatsApp Anda:') %><br>
          <strong style="color: #f1f5f9; font-size: 14px;"><%= phone %></strong>
        </div>

        <% if (error) { %>
          <div class="alert alert-danger mb-4 text-center">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <%= error %>
          </div>
        <% } %>

        <form action="/customer/login-otp" method="POST">
          <div class="form-floating">
            <input type="text" class="form-control otp-input" id="otp" name="otp" placeholder="0000" maxlength="4"
              pattern="\d{4}" required autocomplete="one-time-code" autofocus>
            <label for="otp">
              <i class="bi bi-shield-lock me-2"></i>Kode OTP (4 Digit)
            </label>
          </div>

          <button type="submit" class="btn btn-primary-glow w-100 py-3 mb-4">
            <i class="bi bi-check-circle-fill me-2"></i>Verifikasi & Masuk
          </button>

          <div class="text-center">
            <a href="/customer/login" class="footer-link">
              <i class="bi bi-arrow-left me-1"></i>Kembali ke Login
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</body>

</html>
