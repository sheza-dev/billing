<!DOCTYPE html>
<html lang="<%= lang || 'id' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= t('agent.login_title', 'Login Agent') %> - <%= company %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    body {
      background: radial-gradient(circle at 50% -20%, #1e1b4b 0%, #0f172a 100%) !important;
      color: #f8fafc;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      padding: 16px;
    }

    .login-card {
      background: rgba(30, 41, 59, 0.6) !important;
      border-radius: 20px;
      padding: 32px 28px;
      width: 100%;
      max-width: 420px;
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(99, 102, 241, 0.2) !important;
      box-shadow: 0 0 25px rgba(99, 102, 241, 0.15) !important;
      position: relative;
    }

    .login-card::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 20px;
      padding: 1px;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.4), rgba(59, 130, 246, 0.1));
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      pointer-events: none;
    }

    .form-control {
      background: rgba(15, 23, 42, 0.6) !important;
      border: 1px solid rgba(99, 102, 241, 0.2) !important;
      color: white !important;
      padding: 12px 14px;
      border-radius: 12px;
      transition: all 0.3s ease;
    }

    .form-control:focus {
      background: rgba(15, 23, 42, 0.8) !important;
      color: white !important;
      border-color: #6366f1 !important;
      box-shadow: 0 0 12px rgba(99, 102, 241, 0.45) !important;
    }

    .btn-login {
      background: linear-gradient(135deg, #6366f1 0%, #3b82f6 100%);
      color: white;
      border: none;
      padding: 12px;
      border-radius: 12px;
      width: 100%;
      font-weight: 700;
      margin-top: 15px;
      box-shadow: 0 8px 24px rgba(99, 102, 241, 0.3);
      transition: all 0.3s ease;
    }

    .btn-login:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 28px rgba(99, 102, 241, 0.5);
      opacity: 0.95;
    }

    .brand-icon {
      font-size: 42px;
      color: #818cf8;
      margin-bottom: 12px;
      text-shadow: 0 0 15px rgba(99, 102, 241, 0.5);
    }
  </style>
</head>
<body>
  <div class="login-card text-center">
    <div class="brand-icon"><i class="bi bi-person-badge"></i></div>
    <h3 class="mb-1 fw-bold"><%= t('agent.portal_title', 'Portal Agent') %></h3>
    <p class="text-secondary mb-4 small"><%= company %></p>

    <% if (error) { %>
      <div class="alert alert-danger py-2 small rounded-3">
        <%= error %>
      </div>
    <% } %>

    <form method="POST" action="/agent/login">
      <div class="mb-3 text-start">
        <label class="form-label text-secondary small mb-1"><%= t('agent.username', 'Username') %></label>
        <input type="text" name="username" class="form-control" required placeholder="<%= t('agent.username_placeholder', 'Masukkan username') %>">
      </div>
      <div class="mb-4 text-start">
        <label class="form-label text-secondary small mb-1"><%= t('agent.password', 'Password') %></label>
        <input type="password" name="password" class="form-control" required placeholder="<%= t('agent.password_placeholder', 'Masukkan password') %>">
      </div>
      <button type="submit" class="btn btn-login"><i class="bi bi-box-arrow-in-right me-2"></i> <%= t('agent.sign_in', 'Masuk') %></button>
    </form>
  </div>
</body>
</html>
