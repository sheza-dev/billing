                      <a href="#section-history" class="btn-action w-100" data-bs-dismiss="modal">LIHAT RIWAYAT</a>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <script type="application/json" id="df_brandsDataJson"><%- JSON.stringify(digiflazzBrandsData) %></script>
          <% } %>
        <% } %>
      </div>
