// ── GENIEACS SETTINGS FUNCTIONS ────────────────────────────────
function openGenieACSSettings() {
  openModal('genieacsModal');
}

async function saveGenieACSSettings() {
  const formData = {
    genieacs_timeout: parseInt(document.getElementById('genieacs_timeout').value),
    genieacs_rxpower_threshold: parseFloat(document.getElementById('genieacs_rxpower_threshold').value),
    genieacs_monitoring_interval: parseInt(document.getElementById('genieacs_monitoring_interval').value),
    genieacs_monitoring_enabled: document.getElementById('genieacs_monitoring_enabled').checked
  };

  // Validate
  if (formData.genieacs_timeout < 5000 || formData.genieacs_timeout > 120000) {
    showGenieACSMessage('Timeout harus antara 5000-120000 ms', 'danger');
    return;
  }
  if (formData.genieacs_rxpower_threshold < -40 || formData.genieacs_rxpower_threshold > -15) {
    showGenieACSMessage('RX Power threshold harus antara -40 sampai -15 dBm', 'danger');
    return;
  }
  if (formData.genieacs_monitoring_interval < 1 || formData.genieacs_monitoring_interval > 24) {
    showGenieACSMessage('Monitoring interval harus antara 1-24 jam', 'danger');
    return;
  }

  try {
    const response = await fetch('/admin/api/genieacs/settings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(formData)
    });

    const result = await response.json();
    
    if (result.success) {
      showGenieACSMessage(result.message, 'success');
      setTimeout(() => {
        closeModal('genieacsModal');
        showToast('Pengaturan GenieACS berhasil disimpan', 's');
      }, 1500);
    } else {
      showGenieACSMessage(result.message, 'danger');
    }
  } catch (error) {
    showGenieACSMessage('Error: ' + error.message, 'danger');
  }
}

async function testGenieACSConnection() {
  showGenieACSMessage('Testing koneksi ke GenieACS...', 'info');

  try {
    const response = await fetch('/admin/api/genieacs/test');
    const result = await response.json();
    
    if (result.success) {
      const msg = result.message + (result.deviceCount !== undefined ? ' (' + result.deviceCount + ' devices)' : '');
      showGenieACSMessage(msg, 'success');
    } else {
      showGenieACSMessage('Koneksi gagal: ' + result.message, 'danger');
    }
  } catch (error) {
    showGenieACSMessage('Error: ' + error.message, 'danger');
  }
}

function showGenieACSMessage(msg, type) {
  const messageDiv = document.getElementById('genieacsMessage');
  messageDiv.style.display = 'block';
  
  const colors = {
    success: { bg: 'rgba(63, 185, 80, 0.15)', border: 'rgba(63, 185, 80, 0.3)', text: '#3fb950' },
    danger: { bg: 'rgba(248, 81, 73, 0.15)', border: 'rgba(248, 81, 73, 0.3)', text: '#f85149' },
    info: { bg: 'rgba(102, 126, 234, 0.15)', border: 'rgba(102, 126, 234, 0.3)', text: '#667eea' }
  };
  
  const color = colors[type] || colors.info;
  messageDiv.style.background = color.bg;
  messageDiv.style.border = '1px solid ' + color.border;
  messageDiv.style.color = color.text;
  
  const icons = { success: 'check-circle', danger: 'x-circle', info: 'info-circle' };
  messageDiv.innerHTML = '<i class="bi bi-' + icons[type] + '"></i> ' + msg;
}

function toggleSelectAllMon(master) {
  const checkboxes = document.querySelectorAll('.mon-device-checkbox');
  checkboxes.forEach(cb => cb.checked = master.checked);
  updateMonBulkPanel();
}

function updateMonBulkPanel() {
  const checkboxes = document.querySelectorAll('.mon-device-checkbox:checked');
  const panel = document.getElementById('monBulkActionsPanel');
  const countSpan = document.getElementById('monSelectedCount');
  
  if (checkboxes.length > 0) {
    panel.style.display = 'flex';
    countSpan.textContent = checkboxes.length;
  } else {
    panel.style.display = 'none';
    document.getElementById('selectAllMonDevices').checked = false;
  }
}

function getSelectedMonDevices() {
  const checkboxes = document.querySelectorAll('.mon-device-checkbox:checked');
  const devices = [];
  checkboxes.forEach(cb => {
    devices.push({
      id: cb.dataset.id,
      acsId: cb.dataset.acs
    });
  });
  return devices;
}

async function bulkMonSummon() {
  const devices = getSelectedMonDevices();
  if (devices.length === 0) return;
  if (!confirm(`Summon / Sinkronisasi ulang ${devices.length} perangkat?`)) return;
  
  try {
    const res = await fetch('/admin/acs/api/bulk/refresh', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ devices })
    });
    const d = await res.json();
    showToast(d.message, d.success ? 's' : 'd');
    if (d.success) setTimeout(refreshAll, 1500);
  } catch (err) {
    showToast('Gagal memproses bulk summon: ' + err.message, 'd');
  }
}

async function bulkMonDelete() {
  const devices = getSelectedMonDevices();
  if (devices.length === 0) return;
  if (!confirm(`HAPUS ${devices.length} perangkat dari database ACS?\n(Tindakan ini tidak dapat dibatalkan)`)) return;
  
  try {
    const res = await fetch('/admin/acs/api/bulk/delete', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ devices })
    });
    const d = await res.json();
    showToast(d.message, d.success ? 's' : 'd');
    if (d.success) setTimeout(refreshAll, 1500);
  } catch (err) {
    showToast('Gagal memproses bulk delete: ' + err.message, 'd');
  }
}

async function summonMonDevice(deviceId, acsId) {
  if (!confirm('Summon / Sinkronisasi ulang perangkat ' + deviceId + '?')) return;
  try {
    const res = await fetch('/admin/acs/api/refresh/' + encodeURIComponent(deviceId), {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ acsId })
    });
    const d = await res.json();
    showToast(d.message, d.success ? 's' : 'd');
    if (d.success) setTimeout(refreshAll, 1500);
  } catch (err) {
    showToast('Gagal mengirim summon: ' + err.message, 'd');
  }
}

async function deleteMonDevice(deviceId, acsId) {
  if (!confirm('Hapus perangkat ' + deviceId + ' dari database ACS?')) return;
  try {
    const res = await fetch('/admin/acs/api/device/' + encodeURIComponent(deviceId), {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ acsId })
    });
    const d = await res.json();
    showToast(d.message, d.success ? 's' : 'd');
    if (d.success) setTimeout(refreshAll, 1500);
  } catch (err) {
    showToast('Gagal menghapus perangkat: ' + err.message, 'd');
  }
}

