}

async function saveServer(e) {
    e.preventDefault();
    const btn = document.getElementById('btn-save-acs-server');
    const txt = btn.querySelector('.btn-text');
    const ldr = btn.querySelector('.btn-loader');
    btn.disabled = true;
    txt.style.display = 'none';
    ldr.style.display = 'inline-block';
    const id = document.getElementById('sId').value.trim();
    const body = {
        name: document.getElementById('sName').value,
        url: document.getElementById('sUrl').value,
        username: document.getElementById('sUser').value,
        password: document.getElementById('sPass').value,
        location: document.getElementById('sLoc').value,
        clear_username: document.getElementById('sClearUser').checked,
        clear_password: document.getElementById('sClearPass').checked
    };
    try {
        const isLegacy = id === 'legacy';
        const endpoint = isLegacy ? '/admin/acs/api/servers/legacy' : (id ? ('/admin/acs/api/servers/' + encodeURIComponent(id)) : '/admin/acs/api/servers');
        const method = isLegacy ? 'PUT' : (id ? 'PUT' : 'POST');
        const res = await fetch(endpoint, {
            method,
            headers: {'Content-Type':'application/json'},
            body: JSON.stringify(body)
        });
        const data = await res.json();
        if (data && data.success) return location.reload();
        alert((data && data.message) ? data.message : 'Gagal menyimpan server');
    } finally {
        btn.disabled = false;
        txt.style.display = 'inline-block';
        ldr.style.display = 'none';
    }
}
async function deleteServer(id) {
    if(!confirm('Hapus server ini?')) return;
    const res = await fetch('/admin/acs/api/servers/' + id, { method: 'DELETE' });
    if((await res.json()).success) location.reload();
}
async function refreshDevice(deviceId) {
    if(!confirm('Refresh device ' + deviceId + '?')) return;
    const res = await fetch('/admin/acs/api/refresh/' + encodeURIComponent(deviceId), {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ acsId: '<%= selectedAcsId %>' })
    });
    const d = await res.json();
    alert(d.message);
}
// Sync class active on binding tag label based on checkbox state
function syncTagClass(checkbox, labelId) {
    const lbl = document.getElementById(labelId);
    if (checkbox.checked) {
        lbl.classList.add('active');
    } else {
        lbl.classList.remove('active');
    }
}

// Toggle visibility of PPPoE-specific fields
function toggleWanModeFields() {
    const mode = document.getElementById('wanMode').value;
    const pppoeFields = document.getElementById('pppoeFields');
    const wanDhcp = document.getElementById('wanDhcp');
    if (mode === 'pppoe') {
        pppoeFields.style.display = 'block';
        if (wanDhcp) wanDhcp.checked = true;
    } else {
        pppoeFields.style.display = 'none';
        if (wanDhcp) wanDhcp.checked = false;
    }
}

// Toggle visibility of Profile MikroTik field based on auto-create check
function toggleMikrotikProfileField() {
    const autoChk = document.getElementById('wanAutoMikrotik');
    const container = document.getElementById('pppoeProfileContainer');
    if (autoChk.checked) {
        container.style.visibility = 'visible';
    } else {
        container.style.visibility = 'hidden';
    }
}

// Toggle Wi-Fi configuration slide-down and AJAX fetch
async function toggleWifiFields() {
    const configureWifi = document.getElementById('wanConfigureWifi').checked;
    const wifiFields = document.getElementById('wifiFields');
    
    if (configureWifi) {
        wifiFields.style.display = 'block';
        
        const deviceId = document.getElementById('wanDeviceId').value;
        const acsId = document.getElementById('wanAcsId').value;
        const wifiLoading = document.getElementById('wifiLoading');
        const band24Fields = document.getElementById('band24Fields');
        const band5Fields = document.getElementById('band5Fields');
        
        wifiLoading.style.display = 'block';
        band24Fields.style.opacity = '0.5';
        band5Fields.style.opacity = '0.5';
        
        try {
            const res = await fetch(`/admin/acs/api/wifi-settings/${encodeURIComponent(deviceId)}?acsId=${encodeURIComponent(acsId)}`);
            const d = await res.json();
            
            if (d && d.success && Array.isArray(d.bands)) {
                // Reset fields
                document.getElementById('wifiSsid24').value = '';
                document.getElementById('wifiSsid5').value = '';
                band5Fields.style.display = 'none';
                
                d.bands.forEach(b => {
                    if (b.index === '1') {
                        document.getElementById('wifiSsid24').value = b.ssid;
                        document.getElementById('wifiSsid24').placeholder = 'Nama Wi-Fi 2.4G';
                    } else if (b.index === '5' || b.index === '2') {
                        band5Fields.style.display = 'block';
                        document.getElementById('wifiSsid5').value = b.ssid;
                        document.getElementById('wifiSsid5').placeholder = 'Nama Wi-Fi 5G';
                    }
                });
            }
        } catch (e) {
            console.error('Gagal mengambil SSID perangkat:', e);
        } finally {
            wifiLoading.style.display = 'none';
            band24Fields.style.opacity = '1';
            band5Fields.style.opacity = '1';
        }
    } else {
        wifiFields.style.display = 'none';
    }
}

let addWanProgressTimer = null;
let addWanTrackingState = null;
let addWanLastProgressData = null;

function stopAddWanProgressPolling() {
    if (addWanProgressTimer) {
        clearTimeout(addWanProgressTimer);
        addWanProgressTimer = null;
    }
}

function resetAddWanProgress() {
    stopAddWanProgressPolling();
    addWanTrackingState = null;
    addWanLastProgressData = null;
    const box = document.getElementById('addWanProgressBox');
    const badge = document.getElementById('addWanProgressBadge');
    const summary = document.getElementById('addWanProgressSummary');
    const list = document.getElementById('addWanProgressList');
    const btnCopy = document.getElementById('btnCopyAddWanFailed');
    if (box) box.style.display = 'none';
    if (badge) {
        badge.className = 'text-primary';
        badge.textContent = 'Menunggu';
    }
    if (summary) {
        summary.textContent = 'Workflow belum dimulai.';
    }
    if (list) {
        list.innerHTML = '';
    }
    if (btnCopy) btnCopy.style.display = 'none';
}

async function copyTextToClipboard(text) {
    const content = String(text || '').trim();
    if (!content) return false;
    try {
        if (navigator.clipboard && navigator.clipboard.writeText) {
            await navigator.clipboard.writeText(content);
            return true;
        }
    } catch (_) {}

    try {
        const ta = document.createElement('textarea');
        ta.value = content;
        ta.setAttribute('readonly', 'readonly');
        ta.style.position = 'fixed';
        ta.style.left = '-9999px';
        ta.style.top = '0';
        document.body.appendChild(ta);
        ta.select();
        const ok = document.execCommand('copy');
        document.body.removeChild(ta);
        return !!ok;
    } catch (_) {
        return false;
    }
}

async function copyAddWanFailedLog() {
    const data = addWanLastProgressData;
    if (!data || !data.hasFailure) return;
    const totals = data.totals || {};
    const lines = [];
    lines.push('[ADD WAN] Workflow Gagal (Built-in ACS)');
    lines.push(`Ringkasan: ${data.summary || '-'}`);
    lines.push(`Device: ${addWanTrackingState && addWanTrackingState.deviceId ? addWanTrackingState.deviceId : '-'}`);
    lines.push(`WorkflowId: ${addWanTrackingState && addWanTrackingState.workflowId ? addWanTrackingState.workflowId : '-'}`);
    lines.push(`Total: ${totals.total || 0}, Completed: ${totals.completed || 0}, Failed: ${totals.failed || 0}`);
    lines.push('---');

    const failedDetails = Array.isArray(data.failedDetails) ? data.failedDetails : [];
    if (failedDetails.length > 0) {
        failedDetails.forEach(item => {
            const id = item.id != null ? String(item.id) : '-';
            const label = String(item.label || item.name || 'Task ACS');
            const err = String(item.error || 'Unknown error');
            const info = item.info ? ` | info=${String(item.info)}` : '';
            lines.push(`#${id} ${label} | error=${err}${info}`);
        });
    } else {
        const tasks = Array.isArray(data.tasks) ? data.tasks : [];
        tasks.filter(t => String(t.status) === 'failed').forEach(t => {
            lines.push(`#${t.id} ${t.label || t.name || 'Task ACS'} | status=failed`);
        });
    }

    const ok = await copyTextToClipboard(lines.join('\n'));
    alert(ok ? 'Log task gagal berhasil dicopy.' : 'Gagal copy log. Silakan coba browser lain.');
}

function renderAddWanProgress(data) {
    const box = document.getElementById('addWanProgressBox');
    const badge = document.getElementById('addWanProgressBadge');
    const summary = document.getElementById('addWanProgressSummary');
    const list = document.getElementById('addWanProgressList');
    const btnCopy = document.getElementById('btnCopyAddWanFailed');
    if (!box || !badge || !summary || !list) return;

    box.style.display = 'block';
    summary.textContent = data.summary || 'Workflow sedang diproses.';
    addWanLastProgressData = data;

    if (data.hasFailure) {
        badge.className = 'text-danger';
        badge.textContent = 'Ada Gagal';
    } else if (data.done) {
        badge.className = 'text-success';
        badge.textContent = 'Selesai';
    } else {
        badge.className = 'text-warning';
        badge.textContent = 'Berjalan';
    }
    if (btnCopy) btnCopy.style.display = data.hasFailure ? 'inline-block' : 'none';

    const tasks = Array.isArray(data.tasks) ? data.tasks : [];
    list.innerHTML = tasks.map(task => {
        const status = String(task.status || 'pending');
        let statusClass = 'text-muted';
        let statusLabel = 'Pending';
        if (status === 'completed') {
            statusClass = 'text-success';
            statusLabel = 'Selesai';
        } else if (status === 'failed') {
            statusClass = 'text-danger';
            statusLabel = 'Gagal';
        } else if (status === 'in_progress') {
            statusClass = 'text-warning';
            statusLabel = 'Diproses';
        }
        const label = String(task.label || task.name || 'Task ACS');
        let icon = 'bi-circle';
        if (/Membuat slot WAN/i.test(label)) icon = 'bi-node-plus';
        else if (/Membuat koneksi WAN/i.test(label)) icon = 'bi-diagram-2';
        else if (/VLAN|binding/i.test(label)) icon = 'bi-tags';
        else if (/Wi-?Fi/i.test(label)) icon = 'bi-wifi';
        else if (/DHCP/i.test(label)) icon = 'bi-server';
        else if (/Verifikasi/i.test(label)) icon = 'bi-check2-circle';

        return `
            <div style="display:flex; justify-content:space-between; gap:12px; border:1px dashed var(--border); border-radius:12px; padding:10px 12px; background:rgba(15,23,42,0.08);">
                <span style="font-size:12px; color:var(--text);"><i class="bi ${icon} me-2"></i>${label}</span>
                <span class="${statusClass}" style="font-size:12px; font-weight:700;">${statusLabel}</span>
            </div>
        `;
    }).join('');
}

async function pollAddWanProgress() {
    if (!addWanTrackingState || !addWanTrackingState.deviceId) return;

    const params = new URLSearchParams();
    if (addWanTrackingState.workflowId) params.set('workflowId', addWanTrackingState.workflowId);
    if (addWanTrackingState.rootTaskId) params.set('rootTaskId', String(addWanTrackingState.rootTaskId));

    try {
        const res = await fetch(`/admin/acs/api/add-wan-status/${encodeURIComponent(addWanTrackingState.deviceId)}?${params.toString()}`, {
            cache: 'no-store'
        });
        const data = await res.json();
        if (!data || !data.success) throw new Error(data && data.message ? data.message : 'Gagal membaca progress Add WAN');

        renderAddWanProgress(data);

        if (data.done) {
            stopAddWanProgressPolling();
            const btn = document.getElementById('btn-save-add-wan');
            const txt = btn ? btn.querySelector('.btn-text') : null;
            const ldr = btn ? btn.querySelector('.btn-loader') : null;
            if (btn) btn.disabled = false;
            if (txt) txt.style.display = 'inline-block';
            if (ldr) ldr.style.display = 'none';
            if (!data.hasFailure) {
                setTimeout(() => {
                    closeModal('addWanModal');
                    location.reload();
                }, 1800);
            }
            return;
        }

        addWanProgressTimer = setTimeout(pollAddWanProgress, 4000);
    } catch (err) {
        stopAddWanProgressPolling();
        const summary = document.getElementById('addWanProgressSummary');
        if (summary) summary.textContent = 'Gagal membaca progress workflow Add WAN.';
        const btn = document.getElementById('btn-save-add-wan');
        const txt = btn ? btn.querySelector('.btn-text') : null;
        const ldr = btn ? btn.querySelector('.btn-loader') : null;
        if (btn) btn.disabled = false;
        if (txt) txt.style.display = 'inline-block';
        if (ldr) ldr.style.display = 'none';
    }
}

// Open modal Add WAN All-in-One and populate basic details
async function openAddWanModal(deviceId, acsId, sn, manufacturer, model) {
    resetAddWanProgress();
    document.getElementById('wanDeviceId').value = deviceId;
    document.getElementById('wanAcsId').value = acsId;
    document.getElementById('lblWanSn').innerText = sn || deviceId;
    document.getElementById('lblWanVendor').innerText = manufacturer || '-';
    document.getElementById('lblWanModel').innerText = model || '-';
    
    // Reset form fields
    document.getElementById('wanVlanId').value = '';
    document.getElementById('wanPppoeUser').value = '';
    document.getElementById('wanPppoePass').value = '';
    document.getElementById('wanConfigureWifi').checked = false;
    document.getElementById('wifiFields').style.display = 'none';
    
    // Default active bindings
    document.querySelectorAll('input[name="lanPorts"]').forEach(c => {
        c.checked = true;
        syncTagClass(c, 'lbl' + c.value.charAt(0) + c.value.slice(1).toLowerCase());
    });
    
    // Reset SSID labels to original text first
    for (let i = 1; i <= 4; i++) {
        const lbl = document.getElementById(`lblWlan${i}`);
        if (lbl) {
            lbl.innerHTML = `<input type="checkbox" name="wlanSsids" value="SSID${i}" ${i === 1 ? 'checked' : ''} style="display: none;" onchange="syncTagClass(this, 'lblWlan${i}')"> SSID ${i}`;
            if (i === 1) lbl.classList.add('active');
            else lbl.classList.remove('active');
        }
    }
    
    toggleWanModeFields();
    toggleMikrotikProfileField();
    openModal('addWanModal');
    
    // Async fetch WLAN actual SSID names
    try {
        const res = await fetch(`/admin/acs/api/wifi-settings/${encodeURIComponent(deviceId)}?acsId=${encodeURIComponent(acsId)}`);
        const d = await res.json();
        if (d && d.success && Array.isArray(d.bands)) {
            d.bands.forEach(b => {
                const lbl = document.getElementById(`lblWlan${b.index}`);
                if (lbl) {
                    const isChecked = b.index === '1'; // Default SSID 1 is checked
                    lbl.innerHTML = `<input type="checkbox" name="wlanSsids" value="SSID${b.index}" ${isChecked ? 'checked' : ''} style="display: none;" onchange="syncTagClass(this, 'lblWlan${b.index}')"> SSID ${b.index}: ${b.ssid}`;
                }
            });
        }
    } catch (e) {
        console.error('Gagal mengambil nama SSID:', e);
    }
}

// AJAX submission of the Provisioning form
async function submitAddWanForm(e) {
    e.preventDefault();
    const btn = document.getElementById('btn-save-add-wan');
    const txt = btn.querySelector('.btn-text');
    const ldr = btn.querySelector('.btn-loader');
    
    btn.disabled = true;
    txt.style.display = 'none';
    ldr.style.display = 'inline-block';
    
    const deviceId = document.getElementById('wanDeviceId').value;
    const acsId = document.getElementById('wanAcsId').value;
    
    const lanPorts = [];
    document.querySelectorAll('input[name="lanPorts"]:checked').forEach(c => lanPorts.push(c.value));
    
    const wlanSsids = [];
    document.querySelectorAll('input[name="wlanSsids"]:checked').forEach(c => wlanSsids.push(c.value));
    
    const body = {
        acsId,
        mode: document.getElementById('wanMode').value,
        vlanId: document.getElementById('wanVlanId').value,
        pppoeUser: document.getElementById('wanPppoeUser').value,
        pppoePass: document.getElementById('wanPppoePass').value,
        pppoeProfile: document.getElementById('wanPppoeProfile').value,
        autoCreateMikrotik: document.getElementById('wanAutoMikrotik').checked,
        lanPorts,
        wlanSsids,
        configureWifi: document.getElementById('wanConfigureWifi').checked,
        wifiSsid24: document.getElementById('wifiSsid24').value,
        wifiPass24: document.getElementById('wifiPass24').value,
        wifiSsid5: document.getElementById('wifiSsid5').value,
        wifiPass5: document.getElementById('wifiPass5').value,
        dhcp: document.getElementById('wanDhcp').checked
    };
    
    try {
        const res = await fetch(`/admin/acs/api/add-wan/${encodeURIComponent(deviceId)}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });
        const data = await res.json();
        
        if (data && data.success) {
            if (data.trackingSupported) {
                addWanTrackingState = {
                    deviceId,
                    workflowId: data.workflowId || '',
                    rootTaskId: data.rootTaskId || ''
                };
                renderAddWanProgress({
                    summary: data.message || 'Workflow Add WAN dimulai.',
                    done: false,
                    hasFailure: false,
                    tasks: []
                });
                addWanProgressTimer = setTimeout(pollAddWanProgress, 1200);
            } else {
                alert(data.message);
                closeModal('addWanModal');
                location.reload();
            }
        } else {
            alert(data.message || 'Gagal menjalankan provisioning');
        }
    } catch (err) {
        alert('Terjadi kesalahan: ' + err.message);
    } finally {
        btn.disabled = false;
        txt.style.display = 'inline-block';
        ldr.style.display = 'none';
    }
}

async function syncAllACS() {
    const res = await fetch('/admin/acs/api/sync/all', { method: 'POST' });
    const d = await res.json();
    alert(d.message);
    if(d.success) location.reload();
}

function toggleSelectAll(master) {
    const checkboxes = document.querySelectorAll('.device-checkbox');
    checkboxes.forEach(cb => cb.checked = master.checked);
    updateBulkPanel();
}

function updateBulkPanel() {
    const checkboxes = document.querySelectorAll('.device-checkbox:checked');
    const panel = document.getElementById('bulkActionsPanel');
    const countSpan = document.getElementById('selectedCount');
    
    if (checkboxes.length > 0) {
        panel.style.display = 'flex';
        countSpan.textContent = checkboxes.length;
    } else {
        panel.style.display = 'none';
        document.getElementById('selectAllDevices').checked = false;
    }
}

function getSelectedDevices() {
    const checkboxes = document.querySelectorAll('.device-checkbox:checked');
    const devices = [];
    checkboxes.forEach(cb => {
        devices.push({
            id: cb.dataset.id,
            acsId: cb.dataset.acs
        });
    });
    return devices;
}

async function bulkSummon() {
    const devices = getSelectedDevices();
    if (devices.length === 0) return;
    if (!confirm(`Summon / Sinkronisasi ulang ${devices.length} perangkat?`)) return;
    
    try {
        const res = await fetch('/admin/acs/api/bulk/refresh', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ devices })
        });
        const d = await res.json();
        alert(d.message);
        if (d.success) location.reload();
    } catch (err) {
        alert('Gagal memproses bulk summon: ' + err.message);
    }
}

async function bulkDelete() {
    const devices = getSelectedDevices();
    if (devices.length === 0) return;
    if (!confirm(`HAPUS ${devices.length} perangkat dari database ACS?\n(Tindakan ini tidak dapat dibatalkan)`)) return;
    
    try {
        const res = await fetch('/admin/acs/api/bulk/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ devices })
        });
        const d = await res.json();
        alert(d.message);
        if (d.success) location.reload();
    } catch (err) {
        alert('Gagal memproses bulk delete: ' + err.message);
    }
}

async function deleteDevice(deviceId, acsId) {
    if (!confirm('Hapus perangkat ' + deviceId + ' dari database ACS?')) return;
    try {
        const res = await fetch('/admin/acs/api/device/' + encodeURIComponent(deviceId), {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ acsId })
        });
        const d = await res.json();
        alert(d.message);
        if (d.success) location.reload();
    } catch (err) {
        alert('Gagal menghapus perangkat: ' + err.message);
    }
}

</script>
</body>
