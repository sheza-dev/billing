<!DOCTYPE html>
<html lang="<%= (typeof lang !== 'undefined' ? lang : 'id') %>">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
    <title>GenieACS Pro | <%= (typeof settings !== 'undefined' ? settings.company_header : 'ALIJAYA NET') %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .stats-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:20px; margin-bottom:30px; }
        .stat-card { background:var(--card-bg); border:1px solid var(--border); border-radius:18px; padding:24px; display:flex; align-items:center; gap:20px; cursor:pointer; transition:all 0.3s; position:relative; overflow:hidden; }
        .stat-card:hover { transform:translateY(-5px); border-color:var(--primary); background:var(--sidebar-bg); }
        .stat-card::after { content:''; position:absolute; left:0; top:0; height:100%; width:4px; background:var(--card-color); }
        .stat-icon { width:52px; height:52px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:24px; background:var(--sub-bg); color:var(--card-color); }
        .stat-info h3 { font-size:28px; font-weight:800; margin:0; line-height:1; }
        .stat-info p { font-size:13px; color:var(--muted); margin:8px 0 0; }

        .acs-box { background:var(--card-bg); border:1px solid var(--border); border-radius:22px; overflow:hidden; }
        .tab-bar { display:flex; background:var(--sub-bg); border-bottom:1px solid var(--border); }
        .tab-bar button { padding:18px 25px; background:none; border:none; color:var(--muted); font-weight:600; cursor:pointer; transition:all 0.3s; border-bottom:3px solid transparent; display:flex; align-items:center; gap:8px; font-size:14px; }
        .tab-bar button.active { color:var(--primary); border-bottom-color:var(--primary); background:rgba(59,130,246,0.05); }

        .tab-pane { padding:30px; display:none; animation:fadeIn 0.4s ease; }
        .tab-pane.active { display:block; }
        @keyframes fadeIn { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }

        .table-container { width:100%; overflow-x:auto; }
        table { width:100%; border-collapse:collapse; }
        th { background:var(--sub-bg); color:var(--muted); font-weight:600; font-size:11px; text-transform:uppercase; letter-spacing:1px; padding:15px 20px; text-align:left; }
        td { padding:15px 20px; border-bottom:1px solid var(--border); font-size:13px; color:var(--text); vertical-align:middle; }
        tr:hover td { background:var(--hover-bg); }

        .status-badge { padding:6px 12px; border-radius:20px; font-size:11px; font-weight:700; display:inline-flex; align-items:center; gap:6px; }
        .status-up { background:rgba(16,185,129,0.1); color:#10B981; border:1px solid rgba(16,185,129,0.2); }
        .status-down { background:rgba(239,68,68,0.1); color:#EF4444; border:1px solid rgba(239,68,68,0.2); }

        .btn-action { width:32px; height:32px; border-radius:8px; display:flex; align-items:center; justify-content:center; border:1px solid var(--border); background:var(--sub-bg); color:var(--muted); cursor:pointer; transition:all 0.2s; }
        .btn-action:hover { background:var(--primary); color:white; border-color:var(--primary); transform:scale(1.1); }
        .btn-action.danger:hover { background:var(--danger); border-color:var(--danger); }
        .btn-action:disabled { opacity:0.5; cursor:not-allowed; }
        .btn-action:disabled:hover { background:var(--sub-bg); color:var(--muted); border-color:var(--border); transform:none; }

        .acs-server-tag { display:inline-flex; align-items:center; gap:6px; padding:4px 10px; border-radius:6px; font-size:11px; font-weight:600; background:rgba(59,130,246,0.1); color:var(--primary); border:1px solid rgba(59,130,246,0.2); }
        .acs-server-tag.offline { background:rgba(239,68,68,0.1); color:#EF4444; border-color:rgba(239,68,68,0.2); }

        .modal-overlay { position:fixed; inset:0; background:var(--overlay-bg); backdrop-filter:blur(6px); display:none; align-items:center; justify-content:center; z-index:2000; padding:20px; }
        .modal-card { background:var(--sidebar-bg); border:1px solid var(--border); border-radius:24px; width:100%; max-width:500px; padding:30px; }

        .device-link { text-decoration: none; display: block; transition: all 0.2s; }
        .device-link:hover { opacity: 0.8; }
        .device-link:hover div:first-child { text-decoration: underline; }

        .bind-tag { display: flex; align-items: center; justify-content: center; gap: 6px; padding: 10px; border: 1px solid var(--border); border-radius: 10px; background: var(--card-bg); font-size: 12px; font-weight: 700; cursor: pointer; text-align: center; transition: all 0.2s; color: var(--text); }
        .bind-tag:hover { border-color: var(--primary); background: var(--hover-bg); }
        .bind-tag.active { background: var(--primary) !important; color: white !important; border-color: var(--primary) !important; box-shadow: 0 4px 12px rgba(59,130,246,0.2); }
    </style>
</head>
<body>
<%- include('partials/sidebar', { activePage: 'acs_pro' }) %>
<div class="mw">
    <div class="topbar">
        <div class="tb-title"><button class="hb-menu" onclick="toggleSidebar()"><i class="bi bi-list"></i></button><i class="bi bi-hdd-network"></i> GenieACS Monitoring Pro</div>
        <div class="tb-right">
            <span class="adm-badge"><i class="bi bi-person-fill"></i> <%= (typeof session !== 'undefined' && session.isCashier) ? 'Kasir' : 'Admin' %></span>
            <a href="/admin/logout" class="btn btn-g btn-sm"><i class="bi bi-box-arrow-left"></i></a>
        </div>
    </div>
    <div class="page">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:30px;">
            <h1 class="page-title" style="margin:0;">GenieACS Monitoring</h1>
            <button class="btn btn-p" onclick="syncAllACS()">
                <i class="fas fa-sync-alt"></i> Sync All ACS
            </button>
        </div>

        <div class="stats-grid">
            <div class="stat-card" style="--card-color: var(--primary)">
                <div class="stat-icon"><i class="fas fa-microchip"></i></div>
                <div class="stat-info">
                    <h3><%= devices.length %></h3>
                    <p>Total Devices</p>
                </div>
            </div>
            <div class="stat-card" style="--card-color: #10B981">
                <div class="stat-icon"><i class="fas fa-wifi"></i></div>
                <div class="stat-info">
                    <h3><%= devices.filter(d => d.isOnline).length %></h3>
                    <p>Online</p>
                </div>
            </div>
        </div>

        <div class="acs-box">
            <div class="tab-bar">
                <button class="active" onclick="switchTab('devices', this)"><i class="fas fa-desktop"></i> Devices</button>
                <button onclick="switchTab('servers', this)"><i class="fas fa-server"></i> ACS Servers</button>
            </div>

            <div id="tab-devices" class="tab-pane active">
                <form action="/admin/acs/search" method="GET" class="srow">
                    <div class="sinput" style="max-width:340px">
                        <i class="bi bi-search"></i>
                        <input class="fc" name="q" placeholder="Search SN, Customer, PPPoE..." required>
                    </div>
                    <select class="fs" id="acsFilter" name="acs" style="width:200px" onchange="this.form.submit()">
                        <option value="all">All ACS Servers</option>
                        <% acsServers.forEach(s => { %>
                            <option value="<%= s.id %>" <%= String(selectedAcsId) === String(s.id) ? 'selected' : '' %>><%= s.name %></option>
                        <% }); %>
                    </select>
                    <button class="btn btn-g btn-sm" type="submit"><i class="bi bi-search"></i> Search</button>
                    <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
                        <a href="/admin/acs" class="btn btn-g btn-sm"><i class="bi bi-x"></i> Reset</a>
                    <% } %>
                </form>
                
                <!-- Bulk Actions Panel -->
                <div id="bulkActionsPanel" style="display: none; background: rgba(59,130,246,0.05); border: 1px solid rgba(59,130,246,0.15); padding: 12px 20px; border-radius: 12px; margin-bottom: 20px; align-items: center; justify-content: space-between;">
                    <div style="font-size: 13px; font-weight: 600; color: var(--text);">
                        <span id="selectedCount">0</span> perangkat terpilih
                    </div>
                    <div style="display: flex; gap: 10px;">
                        <button class="btn btn-p btn-sm" onclick="bulkSummon()" style="background: var(--primary);"><i class="fas fa-sync-alt"></i> Summon Terpilih</button>
                        <button class="btn btn-d btn-sm" onclick="bulkDelete()" style="background: var(--danger);"><i class="fas fa-trash"></i> Hapus Terpilih</button>
                    </div>
                </div>

                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th style="width: 40px;"><input type="checkbox" id="selectAllDevices" onchange="toggleSelectAll(this)"></th>
                                <th>Device ID / SN</th>
                                <th>Customer Name</th>
                                <th>IP Address</th>
                                <th>RX Power</th>
                                <th>PPPoE User</th>
                                <th>ACS Server</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% devices.forEach(d => { %>
                            <tr>
                                <td>
                                    <input type="checkbox" class="device-checkbox" data-id="<%= d.id %>" data-acs="<%= d.acs_server_id || selectedAcsId %>" onchange="updateBulkPanel()">
                                </td>
                                <td>
                                    <a href="/admin/acs/device/<%= encodeURIComponent(d.id) %>?acsId=<%= d.acs_server_id || selectedAcsId %>" class="device-link">
                                        <div style="font-weight:700; color:var(--primary);"><%= d.sn %></div>
                                        <div style="font-size:10px; color:var(--muted);"><%= d.id %></div>
                                    </a>
                                </td>
                                <td><%= d.customer_name %></td>
                                <td><code><%= d.ip %></code></td>
                                <td><%= d.rx_power %> dBm</td>
                                <td><%= d.pppoe_user %></td>
                                <td><span class="acs-server-tag"><%= d.acs_server_name %></span></td>
                                <td>
                                    <span class="status-badge <%= d.isOnline ? 'status-up' : 'status-down' %>">
                                        <%= d.isOnline ? 'Online' : 'Offline' %>
                                    </span>
                                </td>
                                <td>
                                    <div style="display:flex; align-items:center; gap:8px;">
                                        <button class="btn-action" onclick="refreshDevice('<%= d.id %>')" title="Refresh Device"><i class="fas fa-sync"></i></button>
                                        <button class="btn-action" onclick="openAddWanModal('<%= d.id %>', '<%= d.acs_server_id || selectedAcsId %>', '<%= d.sn %>', '<%= d.manufacturer || "" %>', '<%= d.model || "" %>')" title="Add WAN All-in-One"><i class="fas fa-network-wired"></i></button>
                                        <button class="btn-action danger" onclick="deleteDevice('<%= d.id %>', '<%= d.acs_server_id || selectedAcsId %>')" title="Hapus Perangkat"><i class="fas fa-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div id="tab-servers" class="tab-pane">
                <div style="display:flex; justify-content:space-between; margin-bottom:20px;">
                    <h3>ACS Servers</h3>
                    <button class="btn btn-p btn-sm" onclick="openAddServerModal()"><i class="bi bi-plus-lg"></i> Add ACS Server</button>
                </div>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>URL</th>
                                <th>Location</th>
                                <th>Devices</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% acsServers.forEach(s => { %>
                            <tr>
                                <td><%= s.name %></td>
                                <td><code><%= s.url %></code></td>
                                <td><%= s.location %></td>
                                <td><%= s.device_count %></td>
                                <td>
                                    <% if (String(s.id) !== 'legacy') { %>
                                        <div style="display:flex;align-items:center;gap:8px">
                                            <button
                                                class="btn-action"
                                                type="button"
                                                onclick="openEditServerModal(this)"
                                                title="Edit"
                                                data-id="<%= s.id %>"
                                                data-name="<%= s.name %>"
                                                data-url="<%= s.url %>"
                                                data-username="<%= s.username || '' %>"
                                                data-location="<%= s.location || '' %>"
                                            >
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <button class="btn-action danger" type="button" onclick="deleteServer('<%= s.id %>')" title="Hapus">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    <% } else { %>
                                        <div style="display:flex;align-items:center;gap:8px">
                                            <button
                                                class="btn-action"
                                                type="button"
                                                onclick="openEditLegacyAcsModal()"
                                                title="Edit Default ACS"
                                            >
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <button class="btn-action danger" type="button" disabled title="Default ACS tidak bisa dihapus">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    <% } %>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <footer style="margin-top: 30px; padding: 20px; text-align: center; color: var(--muted); font-size: 12px; border-top: 1px solid var(--border);">
            &copy; <%= new Date().getFullYear() %> <%= (typeof settings !== 'undefined' ? settings.company_header : 'ALIJAYA NET') %> - GenieACS Pro
        </footer>
    </div>
</div>

<!-- Unified Add WAN All-in-One Modal -->
<div class="mo" id="addWanModal">
  <div class="mb" style="max-width:650px">
    <div class="mh">
      <span class="mt"><i class="fas fa-network-wired"></i> Provisioning All-in-One WAN</span>
      <button class="mc" onclick="closeModal('addWanModal')">&times;</button>
    </div>
    <div class="mbody" style="max-height: 70vh; overflow-y: auto; padding-right: 10px;">
      <form id="addWanForm" onsubmit="submitAddWanForm(event)">
        <input type="hidden" id="wanDeviceId" value="">
        <input type="hidden" id="wanAcsId" value="">
        
        <div style="background: var(--sub-bg); padding: 15px; border-radius: 12px; margin-bottom: 20px; border: 1px dashed var(--border);">
            <div style="display: flex; gap: 15px; font-size: 13px;">
                <div><strong>SN Perangkat:</strong> <span id="lblWanSn" class="text-primary" style="font-weight: 700;">-</span></div>
                <div><strong>Vendor:</strong> <span id="lblWanVendor" style="text-transform: capitalize; font-weight: 700;">-</span></div>
                <div><strong>Tipe:</strong> <span id="lblWanModel" style="font-weight: 700;">-</span></div>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 15px;">
            <div class="fg" style="margin: 0;">
              <label class="fl">WAN Connection Mode</label>
              <select id="wanMode" class="fc" onchange="toggleWanModeFields()" style="height: 42px;">
                <option value="pppoe">PPPoE (Router Mode)</option>
                <option value="bridge">Bridge Mode</option>
              </select>
            </div>
            <div class="fg" style="margin: 0;">
              <label class="fl">VLAN ID</label>
              <input type="number" id="wanVlanId" class="fc" required min="1" max="4094" placeholder="e.g. 100" style="height: 42px;">
            </div>
        </div>

        <div style="margin-bottom: 20px;">
            <label style="display:flex; align-items:center; gap:10px; font-size:13px; color:var(--text); font-weight:700; cursor:pointer;">
              <input type="checkbox" id="wanDhcp" checked style="width:18px; height:18px;">
              <i class="fas fa-server text-primary"></i> Aktifkan DHCP Server LAN (Rekomendasi: Nonaktifkan jika Bridge)
            </label>
        </div>

        <!-- PPPoE Credentials Block -->
        <div id="pppoeFields" style="background: rgba(59,130,246,0.03); border: 1px solid rgba(59,130,246,0.1); padding: 18px; border-radius: 16px; margin-bottom: 15px;">
            <h4 style="margin: 0 0 12px 0; font-size: 14px; color: var(--primary);"><i class="fas fa-key"></i> Kredensial PPPoE</h4>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 12px;">
                <div class="fg" style="margin: 0;">
                  <label class="fl">Username PPPoE</label>
                  <input type="text" id="wanPppoeUser" class="fc" placeholder="e.g. customer123">
                </div>
                <div class="fg" style="margin: 0;">
                  <label class="fl">Password PPPoE</label>
                  <input type="text" id="wanPppoePass" class="fc" placeholder="e.g. secretpass">
                </div>
            </div>
            <div style="display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 15px; align-items: center; margin-top: 15px; padding-top: 12px; border-top: 1px dashed var(--border);">
                <div>
                    <label style="display:flex; align-items:center; gap:8px; font-size:12px; color:var(--text); font-weight:600; cursor:pointer;">
                      <input type="checkbox" id="wanAutoMikrotik" checked style="width:18px; height:18px;" onchange="toggleMikrotikProfileField()">
                      Auto-create PPPoE Secret di MikroTik
                    </label>
                </div>
                <div class="fg" style="margin: 0;" id="pppoeProfileContainer">
                  <label class="fl">Profile MikroTik</label>
                  <select id="wanPppoeProfile" class="fc" style="height: 38px;">
                    <% pppoeProfiles.forEach(p => { %>
                        <option value="<%= p.name %>" <%= p.name === 'default' ? 'selected' : '' %>><%= p.name %></option>
                    <% }); %>
                  </select>
                </div>
            </div>
        </div>

        <!-- Unified Wi-Fi Block -->
        <div style="border: 1px solid var(--border); border-radius: 16px; margin-bottom: 20px; overflow: hidden;">
            <div style="background: var(--sub-bg); padding: 12px 18px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border);">
                <label style="display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 13px; cursor: pointer; margin: 0; width: 100%;">
                    <input type="checkbox" id="wanConfigureWifi" onchange="toggleWifiFields()" style="width: 18px; height: 18px;">
                    <i class="fas fa-wifi text-primary"></i> Konfigurasikan Wi-Fi Sekaligus
                </label>
            </div>
            <div id="wifiFields" style="display: none; padding: 20px; background: rgba(16,185,129,0.01);">
                <div id="wifiLoading" style="text-align: center; padding: 15px; color: var(--muted);">
                    <i class="bi bi-arrow-clockwise spin" style="font-size: 20px;"></i> Mengunduh SSID lama...
                </div>
                <div id="wifiBandsContainer" style="display: grid; gap: 15px;">
                    <!-- 2.4GHz Band -->
                    <div id="band24Fields" style="display: block;">
                        <h5 style="margin: 0 0 10px 0; font-size: 13px; color: var(--text); font-weight: 700;"><i class="fas fa-broadcast-tower"></i> Wi-Fi 2.4GHz</h5>
                        <div class="form-row2">
                            <div class="fg" style="margin: 0;">
                              <label class="fl">SSID (Nama Wi-Fi)</label>
                              <input type="text" id="wifiSsid24" class="fc" placeholder="Mengunduh...">
                            </div>
                            <div class="fg" style="margin: 0;">
                              <label class="fl">Sandi Wi-Fi (WPA2)</label>
                              <input type="password" id="wifiPass24" class="fc" placeholder="Biarkan kosong jika tidak diganti">
                            </div>
                        </div>
                    </div>
                    <!-- 5GHz Band -->
                    <div id="band5Fields" style="display: none; border-top: 1px dashed var(--border); padding-top: 15px; margin-top: 10px;">
                        <h5 style="margin: 0 0 10px 0; font-size: 13px; color: var(--text); font-weight: 700;"><i class="fas fa-bolt"></i> Wi-Fi 5GHz</h5>
                        <div class="form-row2">
                            <div class="fg" style="margin: 0;">
                              <label class="fl">SSID (Nama Wi-Fi)</label>
                              <input type="text" id="wifiSsid5" class="fc" placeholder="Mengunduh...">
                            </div>
                            <div class="fg" style="margin: 0;">
                              <label class="fl">Sandi Wi-Fi (WPA2)</label>
                              <input type="password" id="wifiPass5" class="fc" placeholder="Biarkan kosong jika tidak diganti">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- LAN / WLAN Port Binding -->
        <div style="background: var(--sub-bg); border: 1px solid var(--border); padding: 18px; border-radius: 16px; margin-bottom: 5px;">
            <h4 style="margin: 0 0 12px 0; font-size: 13px; color: var(--text); font-weight: 700;"><i class="fas fa-bezier-curve text-primary"></i> LAN / WLAN Port Binding</h4>
            
            <label class="fl" style="margin-bottom: 8px;">Pilih LAN Port yang akan di-bind:</label>
            <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 15px;">
                <label class="bind-tag active" id="lblLan1">
                    <input type="checkbox" name="lanPorts" value="LAN1" checked style="display: none;" onchange="syncTagClass(this, 'lblLan1')"> LAN 1
                </label>
                <label class="bind-tag active" id="lblLan2">
                    <input type="checkbox" name="lanPorts" value="LAN2" checked style="display: none;" onchange="syncTagClass(this, 'lblLan2')"> LAN 2
                </label>
                <label class="bind-tag active" id="lblLan3">
                    <input type="checkbox" name="lanPorts" value="LAN3" checked style="display: none;" onchange="syncTagClass(this, 'lblLan3')"> LAN 3
                </label>
                <label class="bind-tag active" id="lblLan4">
                    <input type="checkbox" name="lanPorts" value="LAN4" checked style="display: none;" onchange="syncTagClass(this, 'lblLan4')"> LAN 4
                </label>
            </div>

            <label class="fl" style="margin-bottom: 8px;">Pilih WLAN (SSID) yang akan di-bind:</label>
            <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;">
                <label class="bind-tag active" id="lblWlan1">
                    <input type="checkbox" name="wlanSsids" value="SSID1" checked style="display: none;" onchange="syncTagClass(this, 'lblWlan1')"> SSID 1
                </label>
                <label class="bind-tag" id="lblWlan2">
                    <input type="checkbox" name="wlanSsids" value="SSID2" style="display: none;" onchange="syncTagClass(this, 'lblWlan2')"> SSID 2
                </label>
                <label class="bind-tag" id="lblWlan3">
                    <input type="checkbox" name="wlanSsids" value="SSID3" style="display: none;" onchange="syncTagClass(this, 'lblWlan3')"> SSID 3
                </label>
                <label class="bind-tag" id="lblWlan4">
                    <input type="checkbox" name="wlanSsids" value="SSID4" style="display: none;" onchange="syncTagClass(this, 'lblWlan4')"> SSID 4
                </label>
            </div>
        </div>

        <div id="addWanProgressBox" style="display:none; margin-top:16px; border:1px solid var(--border); border-radius:16px; padding:16px; background:rgba(59,130,246,0.04);">
