<!DOCTYPE html>
<html lang="<%= (typeof lang !== 'undefined' ? lang : 'id') %>">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
    <title>GenieACS Pro | <%= (typeof settings !== 'undefined' ? settings.company_header : 'ALIJAYA NET') %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .stats-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:20px; margin-bottom:30px; }
        .stat-card { background:var(--card-bg); border:1px solid var(--border); border-radius:18px; padding:24px; display:flex; align-items:center; gap:20px; cursor:pointer; transition:all 0.3s; position:relative; overflow:hidden; }
        .stat-card:hover { transform:translateY(-5px); border-color:var(--primary); background:var(--sidebar-bg); }
        .stat-card::after { content:''; position:absolute; left:0; top:0; height:100%; width:4px; background:var(--card-color); }
        .stat-icon { width:52px; height:52px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:24px; background:var(--sub-bg); color:var(--card-color); }
        .stat-info h3 { font-size:28px; font-weight:800; margin:0; line-height:1; }
        .stat-info p { font-size:13px; color:var(--muted); margin:8px 0 0; }

        .acs-box { background:var(--card-bg); border:1px solid var(--border); border-radius:22px; overflow:hidden; }
        .tab-bar { display:flex; background:var(--sub-bg); border-bottom:1px solid var(--border); }
        .tab-bar button { padding:18px 25px; background:none; border:none; color:var(--muted); font-weight:600; cursor:pointer; transition:all 0.3s; border-bottom:3px solid transparent; display:flex; align-items:center; gap:8px; font-size:14px; }
        .tab-bar button.active { color:var(--primary); border-bottom-color:var(--primary); background:rgba(59,130,246,0.05); }

        .tab-pane { padding:30px; display:none; animation:fadeIn 0.4s ease; }
        .tab-pane.active { display:block; }
        @keyframes fadeIn { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }

        .table-container { width:100%; overflow-x:auto; }
        table { width:100%; border-collapse:collapse; }
        th { background:var(--sub-bg); color:var(--muted); font-weight:600; font-size:11px; text-transform:uppercase; letter-spacing:1px; padding:15px 20px; text-align:left; }
        td { padding:15px 20px; border-bottom:1px solid var(--border); font-size:13px; color:var(--text); vertical-align:middle; }
        tr:hover td { background:var(--hover-bg); }

        .status-badge { padding:6px 12px; border-radius:20px; font-size:11px; font-weight:700; display:inline-flex; align-items:center; gap:6px; }
        .status-up { background:rgba(16,185,129,0.1); color:#10B981; border:1px solid rgba(16,185,129,0.2); }
        .status-down { background:rgba(239,68,68,0.1); color:#EF4444; border:1px solid rgba(239,68,68,0.2); }

        .btn-action { width:32px; height:32px; border-radius:8px; display:flex; align-items:center; justify-content:center; border:1px solid var(--border); background:var(--sub-bg); color:var(--muted); cursor:pointer; transition:all 0.2s; }
        .btn-action:hover { background:var(--primary); color:white; border-color:var(--primary); transform:scale(1.1); }
        .btn-action.danger:hover { background:var(--danger); border-color:var(--danger); }
        .btn-action:disabled { opacity:0.5; cursor:not-allowed; }
        .btn-action:disabled:hover { background:var(--sub-bg); color:var(--muted); border-color:var(--border); transform:none; }

        .filter-bar { display:flex; gap:15px; margin-bottom:20px; align-items:center; flex-wrap:wrap; }
        .filter-select { background:var(--card-bg); border:1px solid var(--border); border-radius:10px; padding:10px 15px; color:var(--text); font-size:13px; cursor:pointer; min-width:180px; }
        .filter-select:focus { outline:none; border-color:var(--primary); }

        .acs-server-tag { display:inline-flex; align-items:center; gap:6px; padding:4px 10px; border-radius:6px; font-size:11px; font-weight:600; background:rgba(59,130,246,0.1); color:var(--primary); border:1px solid rgba(59,130,246,0.2); }
        .acs-server-tag.offline { background:rgba(239,68,68,0.1); color:#EF4444; border-color:rgba(239,68,68,0.2); }

        .modal-overlay { position:fixed; inset:0; background:var(--overlay-bg); backdrop-filter:blur(6px); display:none; align-items:center; justify-content:center; z-index:2000; padding:20px; }
        .modal-card { background:var(--sidebar-bg); border:1px solid var(--border); border-radius:24px; width:100%; max-width:500px; padding:30px; }

        .device-link { text-decoration: none; display: block; transition: all 0.2s; }
        .device-link:hover { opacity: 0.8; }
        .device-link:hover div:first-child { text-decoration: underline; }
    </style>
</head>
<body>
<%- include('partials/sidebar', { activePage: 'acs_pro' }) %>
<div class="mw">
    <div class="topbar">
        <div class="tb-title"><button class="hb-menu" onclick="toggleSidebar()"><i class="bi bi-list"></i></button><i class="bi bi-hdd-network"></i> GenieACS Monitoring Pro</div>
        <div class="tb-right">
            <span class="adm-badge"><i class="bi bi-person-fill"></i> <%= (typeof session !== 'undefined' && session.isCashier) ? 'Kasir' : 'Admin' %></span>
            <a href="/admin/logout" class="btn btn-g btn-sm"><i class="bi bi-box-arrow-left"></i></a>
        </div>
    </div>
    <div class="page">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:30px;">
            <h1 class="page-title" style="margin:0;">GenieACS Monitoring</h1>
            <button class="btn btn-p" onclick="syncAllACS()">
                <i class="fas fa-sync-alt"></i> Sync All ACS
            </button>
        </div>

        <div class="stats-grid">
            <div class="stat-card" style="--card-color: var(--primary)">
                <div class="stat-icon"><i class="fas fa-microchip"></i></div>
                <div class="stat-info">
                    <h3><%= devices.length %></h3>
                    <p>Total Devices</p>
                </div>
            </div>
            <div class="stat-card" style="--card-color: #10B981">
                <div class="stat-icon"><i class="fas fa-wifi"></i></div>
                <div class="stat-info">
                    <h3><%= devices.filter(d => d.isOnline).length %></h3>
                    <p>Online</p>
                </div>
            </div>
        </div>

        <div class="acs-box">
            <div class="tab-bar">
                <button class="active" onclick="switchTab('devices', this)"><i class="fas fa-desktop"></i> Devices</button>
                <button onclick="switchTab('servers', this)"><i class="fas fa-server"></i> ACS Servers</button>
            </div>

            <div id="tab-devices" class="tab-pane active">
                <div class="filter-bar">
                    <form action="/admin/acs/search" method="GET" style="display:flex; gap:10px; flex:1;">
                        <input type="text" name="q" class="form-control" placeholder="Search SN, Customer, PPPoE..." required>
                        <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i></button>
                    </form>
                    <select id="acsFilter" class="filter-select" onchange="location.href='/admin/acs?acs='+this.value">
                        <option value="all">All ACS Servers</option>
                        <% acsServers.forEach(s => { %>
                            <option value="<%= s.id %>" <%= String(selectedAcsId) === String(s.id) ? 'selected' : '' %>><%= s.name %></option>
                        <% }); %>
                    </select>
                </div>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Device ID / SN</th>
                                <th>Customer Name</th>
                                <th>IP Address</th>
                                <th>RX Power</th>
                                <th>PPPoE User</th>
                                <th>ACS Server</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% devices.forEach(d => { %>
                            <tr>
                                <td>
                                    <a href="/admin/acs/device/<%= encodeURIComponent(d.id) %>?acsId=<%= d.acs_server_id || selectedAcsId %>" class="device-link">
                                        <div style="font-weight:700; color:var(--primary);"><%= d.sn %></div>
                                        <div style="font-size:10px; color:var(--muted);"><%= d.id %></div>
                                    </a>
                                </td>
                                <td><%= d.customer_name %></td>
                                <td><code><%= d.ip %></code></td>
                                <td><%= d.rx_power %> dBm</td>
                                <td><%= d.pppoe_user %></td>
                                <td><span class="acs-server-tag"><%= d.acs_server_name %></span></td>
                                <td>
                                    <span class="status-badge <%= d.isOnline ? 'status-up' : 'status-down' %>">
                                        <%= d.isOnline ? 'Online' : 'Offline' %>
                                    </span>
                                </td>
                                <td>
                                    <button class="btn-action" onclick="refreshDevice('<%= d.id %>')"><i class="fas fa-sync"></i></button>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div id="tab-servers" class="tab-pane">
                <div style="display:flex; justify-content:space-between; margin-bottom:20px;">
                    <h3>ACS Servers</h3>
                    <button class="btn btn-p btn-sm" onclick="openAddServerModal()"><i class="bi bi-plus-lg"></i> Add ACS Server</button>
                </div>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>URL</th>
                                <th>Location</th>
                                <th>Devices</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% acsServers.forEach(s => { %>
                            <tr>
                                <td><%= s.name %></td>
                                <td><code><%= s.url %></code></td>
                                <td><%= s.location %></td>
                                <td><%= s.device_count %></td>
                                <td>
                                    <% if (String(s.id) !== 'legacy') { %>
                                        <div style="display:flex;align-items:center;gap:8px">
                                            <button
                                                class="btn-action"
                                                type="button"
                                                onclick="openEditServerModal(this)"
                                                title="Edit"
                                                data-id="<%= s.id %>"
                                                data-name="<%= s.name %>"
                                                data-url="<%= s.url %>"
                                                data-username="<%= s.username || '' %>"
                                                data-location="<%= s.location || '' %>"
                                            >
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <button class="btn-action danger" type="button" onclick="deleteServer('<%= s.id %>')" title="Hapus">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    <% } else { %>
                                        <div style="display:flex;align-items:center;gap:8px">
                                            <button
                                                class="btn-action"
                                                type="button"
                                                onclick="openEditLegacyAcsModal()"
                                                title="Edit Default ACS"
                                            >
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <button class="btn-action danger" type="button" disabled title="Default ACS tidak bisa dihapus">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    <% } %>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <footer style="margin-top: 30px; padding: 20px; text-align: center; color: var(--muted); font-size: 12px; border-top: 1px solid var(--border);">
            &copy; <%= new Date().getFullYear() %> <%= (typeof settings !== 'undefined' ? settings.company_header : 'ALIJAYA NET') %> - GenieACS Pro
        </footer>
    </div>
</div>

<div class="mo" id="serverModal">
  <div class="mb" style="max-width:560px">
    <div class="mh">
      <span class="mt" id="acsServerModalTitle"><i class="bi bi-server"></i> Add ACS Server</span>
      <button class="mc" onclick="closeModal('serverModal')">&times;</button>
    </div>
    <div class="mbody">
      <form id="acsServerForm" onsubmit="saveServer(event)">
        <input type="hidden" id="sId" value="">
        <div class="fg">
          <label class="fl">Server Name</label>
          <input type="text" id="sName" class="fc" required placeholder="e.g. Server Pusat">
        </div>
        <div class="fg">
          <label class="fl">API URL</label>
          <input type="text" id="sUrl" class="fc" required placeholder="http://192.168.1.10:7557">
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="fg" style="margin:0">
            <label class="fl">Username</label>
            <input type="text" id="sUser" class="fc" placeholder="Optional">
            <label style="display:flex;align-items:center;gap:8px;margin-top:8px;font-size:12px;color:var(--muted);font-weight:600">
              <input type="checkbox" id="sClearUser" style="width:16px;height:16px">
              Kosongkan username
            </label>
          </div>
          <div class="fg" style="margin:0">
            <label class="fl">Password</label>
            <input type="password" id="sPass" class="fc" placeholder="Optional">
            <label style="display:flex;align-items:center;gap:8px;margin-top:8px;font-size:12px;color:var(--muted);font-weight:600">
              <input type="checkbox" id="sClearPass" style="width:16px;height:16px">
              Kosongkan password
            </label>
          </div>
        </div>
        <div class="fg">
          <label class="fl">Location / Note</label>
          <input type="text" id="sLoc" class="fc" placeholder="e.g. Data Center">
        </div>
      </form>
    </div>
    <div class="mf">
      <button type="button" class="btn btn-g" onclick="closeModal('serverModal')">Batal</button>
      <button type="submit" form="acsServerForm" class="btn btn-p" id="btn-save-acs-server">
        <span class="btn-text"><i class="bi bi-save"></i> Simpan</span>
        <span class="btn-loader" style="display:none"><i class="bi bi-arrow-clockwise spin"></i> Menyimpan...</span>
      </button>
    </div>
  </div>
</div>

<script>
function switchTab(id, btn) {
    document.querySelectorAll('.tab-pane').forEach(c => c.classList.remove('active'));
    document.querySelectorAll('.tab-bar button').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + id).classList.add('active');
    btn.classList.add('active');
}

function openModal(id) { document.getElementById(id).classList.add('show'); }
function closeModal(id) { document.getElementById(id).classList.remove('show'); }
document.querySelectorAll('.mo').forEach(m => m.addEventListener('click', e => { if (e.target === m) m.classList.remove('show'); }));

function openAddServerModal() {
    document.getElementById('acsServerModalTitle').innerHTML = '<i class="bi bi-server"></i> Add ACS Server';
    document.getElementById('sId').value = '';
    document.getElementById('sName').value = '';
    document.getElementById('sUrl').value = '';
    document.getElementById('sUser').value = '';
    document.getElementById('sPass').value = '';
    document.getElementById('sLoc').value = '';
    document.getElementById('sClearUser').checked = false;
    document.getElementById('sClearPass').checked = false;
    document.getElementById('sName').disabled = false;
    document.getElementById('sLoc').disabled = false;
    openModal('serverModal');
}

function openEditServerModal(btn) {
    document.getElementById('acsServerModalTitle').innerHTML = '<i class="bi bi-server"></i> Edit ACS Server';
    document.getElementById('sId').value = btn.dataset.id || '';
    document.getElementById('sName').value = btn.dataset.name || '';
    document.getElementById('sUrl').value = btn.dataset.url || '';
    document.getElementById('sUser').value = btn.dataset.username || '';
    document.getElementById('sPass').value = '';
    document.getElementById('sLoc').value = btn.dataset.location || '';
    document.getElementById('sClearUser').checked = false;
    document.getElementById('sClearPass').checked = false;
    document.getElementById('sName').disabled = false;
    document.getElementById('sLoc').disabled = false;
    openModal('serverModal');
}

function openEditLegacyAcsModal() {
    document.getElementById('acsServerModalTitle').innerHTML = '<i class="bi bi-server"></i> Edit Default ACS';
    document.getElementById('sId').value = 'legacy';
    document.getElementById('sName').value = 'Default ACS';
    document.getElementById('sUrl').value = '<%= (typeof settings !== "undefined" && settings.genieacs_url) ? String(settings.genieacs_url) : "" %>';
    document.getElementById('sUser').value = '<%= (typeof settings !== "undefined" && settings.genieacs_username) ? String(settings.genieacs_username) : "" %>';
    document.getElementById('sPass').value = '';
    document.getElementById('sLoc').value = '';
    document.getElementById('sClearUser').checked = false;
    document.getElementById('sClearPass').checked = false;
    document.getElementById('sName').disabled = true;
    document.getElementById('sLoc').disabled = true;
    openModal('serverModal');
}

async function saveServer(e) {
    e.preventDefault();
    const btn = document.getElementById('btn-save-acs-server');
    const txt = btn.querySelector('.btn-text');
    const ldr = btn.querySelector('.btn-loader');
    btn.disabled = true;
    txt.style.display = 'none';
    ldr.style.display = 'inline-block';
    const id = document.getElementById('sId').value.trim();
    const body = {
        name: document.getElementById('sName').value,
        url: document.getElementById('sUrl').value,
        username: document.getElementById('sUser').value,
        password: document.getElementById('sPass').value,
        location: document.getElementById('sLoc').value,
        clear_username: document.getElementById('sClearUser').checked,
        clear_password: document.getElementById('sClearPass').checked
    };
    try {
        const isLegacy = id === 'legacy';
        const endpoint = isLegacy ? '/admin/acs/api/servers/legacy' : (id ? ('/admin/acs/api/servers/' + encodeURIComponent(id)) : '/admin/acs/api/servers');
        const method = isLegacy ? 'PUT' : (id ? 'PUT' : 'POST');
        const res = await fetch(endpoint, {
            method,
            headers: {'Content-Type':'application/json'},
            body: JSON.stringify(body)
        });
        const data = await res.json();
        if (data && data.success) return location.reload();
        alert((data && data.message) ? data.message : 'Gagal menyimpan server');
    } finally {
        btn.disabled = false;
        txt.style.display = 'inline-block';
        ldr.style.display = 'none';
    }
}
async function deleteServer(id) {
    if(!confirm('Hapus server ini?')) return;
    const res = await fetch('/admin/acs/api/servers/' + id, { method: 'DELETE' });
    if((await res.json()).success) location.reload();
}
async function refreshDevice(deviceId) {
    if(!confirm('Refresh device ' + deviceId + '?')) return;
    const res = await fetch('/admin/acs/api/refresh/' + encodeURIComponent(deviceId), {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ acsId: '<%= selectedAcsId %>' })
    });
    const d = await res.json();
    alert(d.message);
}
async function syncAllACS() {
    const res = await fetch('/admin/acs/api/sync/all', { method: 'POST' });
    const d = await res.json();
    alert(d.message);
    if(d.success) location.reload();
}
</script>
</body>
</html>
