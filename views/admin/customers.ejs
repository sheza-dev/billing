    });
  } catch (e) {
    console.error('Failed to load MikroTik profiles', e);
  }
}

async function loadPppoeAddMulti(routerIds = []) {
  try {
    const allUsers = [];
    const seenNames = new Set();
    const routerMap = {}; // Track which router each user comes from
    
    for (const routerId of routerIds) {
      try {
        const url = `/admin/api/mikrotik/users?routerId=${encodeURIComponent(routerId)}&onlyUnused=1`;
        const res = await fetch(url);
        if (!res.ok) continue;
        const users = await res.json();
        
        for (const u of users) {
          if (u && u.name && !seenNames.has(u.name)) {
            allUsers.push(u);
            routerMap[u.name] = routerId;
            seenNames.add(u.name);
          }
        }
      } catch (e) {
        console.error(`Failed to load PPPoE users from router ${routerId}`, e);
      }
    }
    
    const datalist = document.getElementById('add_pppoe_list');
    if (datalist) {
      datalist.innerHTML = '';
      allUsers.forEach(u => {
        datalist.insertAdjacentHTML('beforeend', `<option value="${String(u.name).replace(/"/g, '&quot;')}"></option>`);
      });
    }
    
    const hint = document.getElementById('add_pppoe_hint');
    if (hint) {
      if (allUsers.length > 0) {
        const routerList = [...new Set(Object.values(routerMap))].join(', ');
        hint.innerText = `Tersedia ${allUsers.length} user PPPoE dari ${routerIds.length} router (yang belum dipakai).`;
      } else {
        hint.innerText = 'Tidak ada user PPPoE yang tersedia di router terpilih.';
      }
    }
  } catch (e) {
    console.error('Failed to load multiple router PPPoE users', e);
  }
}

